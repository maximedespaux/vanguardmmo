# ─── Base de données PostgreSQL (obligatoire maintenant) ───
DATABASE_URL="postgresql://vanguard:vanguard@localhost:5432/vanguard"

# ─── NextAuth / Discord OAuth ───
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genere-avec: openssl rand -base64 32"
DISCORD_CLIENT_ID="ton_client_id"
DISCORD_CLIENT_SECRET="ton_client_secret"     # ⚠️ régénère-le (l'ancien a été exposé)
DISCORD_GUILD_ID="id_de_ta_guilde_vanguard"

# ─── IDs des rôles Discord (clic droit rôle → Copier l'identifiant) ───
ROLE_DIRECTION=""
ROLE_VANGUARD=""
ROLE_GENERAL=""
ROLE_OFFICIER=""
ROLE_VETERAN=""
ROLE_GUARD=""

# ─── Webhook #candidatures ───
DISCORD_CANDIDATURES_WEBHOOK=""

# ─── BOT DISCORD ───
# Token du bot (Discord Developer Portal → ton app → Bot → Reset Token)
DISCORD_BOT_TOKEN=""
# Salons où le bot poste (clic droit salon → Copier l'identifiant)
CHANNEL_CANDIDATURES=""   # relances de candidatures (fallback si pas de salon staff)
CHANNEL_EVENTS=""         # rappels d'événements du jeu
CHANNEL_STAFF=""          # salon officiers (optionnel, prioritaire pour les relances)

# ─── Mode dev local ───
# "1" (défaut) : simule un utilisateur connecté (rôle Direction) en base, sans Discord → localhost = prod.
# "0" : exige la vraie connexion Discord + vérification des rôles.
DEV_ALL_ACCESS="1"
NEXT_PUBLIC_DEV_ALL_ACCESS="1"
