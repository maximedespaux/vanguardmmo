# ════════════════════════════════════════════════════════════
#  .env de PRODUCTION — copier en `.env` sur le serveur et remplir.
#  (NE JAMAIS committer le vrai .env — il est dans .gitignore)
# ════════════════════════════════════════════════════════════

# ── PostgreSQL (conteneur `db` du docker-compose) ──
POSTGRES_USER=vanguard
POSTGRES_PASSWORD=CHANGE_MOI_mot_de_passe_solide
POSTGRES_DB=vanguard

# ⚠️ host = "db" (nom du service compose), port interne 5432
DATABASE_URL="postgresql://vanguard:CHANGE_MOI_mot_de_passe_solide@db:5432/vanguard"

# ── NextAuth (site) ──
NEXTAUTH_URL="https://LE-DOMAINE"          # ex: https://vanguard.mondomaine.fr
NEXTAUTH_SECRET="GENERER:  openssl rand -base64 32"

# ── Discord — application (OAuth du site) ──
DISCORD_CLIENT_ID="..."
DISCORD_CLIENT_SECRET="..."                # régénéré pour la prod

# ── Discord — bot ──
DISCORD_BOT_TOKEN="..."                     # régénéré pour la prod
DISCORD_GUILD_ID="..."

# ── Salons (⚠️ #decisions & #candidatures = FORUM) ──
CHANNEL_DECISION="..."
CHANNEL_CANDIDATURES="..."
CHANNEL_STAFF="..."
CHANNEL_EVENTS="..."

# ── Rôles : rangs ──
ROLE_DIRECTION="..."
ROLE_VANGUARD="..."
ROLE_GENERAL="..."
ROLE_OFFICIER="..."
ROLE_VETERAN="..."
ROLE_GUARD="..."

# ── Rôles : 8 classes ──
ROLE_CLASSE_SPADASSIN="..."
ROLE_CLASSE_TEMPLIER="..."
ROLE_CLASSE_ARCANISTE="..."
ROLE_CLASSE_ENVOUTEUR="..."
ROLE_CLASSE_ARBALETRIER="..."
ROLE_CLASSE_SYLPHIDE="..."
ROLE_CLASSE_PRIMAT="..."
ROLE_CLASSE_CHANOINE="..."

# ── Rôles : spécialisations ──
ROLE_SPEC_CHAMBRES_SECRETES="..."
ROLE_SPEC_PVE="..."
ROLE_SPEC_PVP="..."

# ⚠️ NE PAS mettre DEV_ALL_ACCESS en prod (la connexion Discord devient obligatoire).
